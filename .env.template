# Twilio credentials — https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+15550000000

# Public Funnel URL where Twilio reaches this app
BASE_URL=https://your-funnel-hostname.ts.net

# Tailnet MagicDNS hostname for the private inbox (no scheme/port)
TAILNET_HOSTNAME=your-pi.your-tailnet.ts.net

# Set false only for local dev/testing — never in production
TWILIO_VALIDATION_ENABLED=true

# Absolute path to the data directory
DATA_DIR=/absolute/path/to/family-call-center-public/data

# Flask
FLASK_SECRET_KEY=change-me-to-a-random-string

# Pushover notifications (https://pushover.net)
PUSHOVER_TOKEN=
PUSHOVER_USER=

# Weather (Open-Meteo) — your coordinates (kept out of git)
WEATHER_LAT=
WEATHER_LON=
WEATHER_PLACE_NAME=

# Wardrobe rules + day overrides (defaults point at config/*.yml in the repo)
WARDROBE_CONFIG=
DAY_OVERRIDES=

# Set false only in tests; the scheduler thread refreshes the weather cache
SCHEDULER_ENABLED=true

# Deepgram Aura voice (optional). Empty key = Twilio's built-in voice.
# Get a key at https://console.deepgram.com ; paste it into your real .env.
DEEPGRAM_API_KEY=
DEEPGRAM_TTS_MODEL=aura-2-andromeda-en
